{
  "name": "nova-ai",
  "private": true,
  "version": "1.0.0",
  "description": "Nova AI — World-class AI chat app with agents, multi-model, memory",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
