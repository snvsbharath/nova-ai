# ─── Nova AI — Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (comma-separated list of allowed frontend origins) ───────────────────
# In production, set this to your actual frontend URL:
# ALLOWED_ORIGINS=https://your-nova-ai.netlify.app,https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173
